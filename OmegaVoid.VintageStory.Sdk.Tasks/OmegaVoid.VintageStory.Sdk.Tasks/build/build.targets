<Project>
    <!-- Creating local settings file -->
    <Target Name="EnsureSettingsProps" BeforeTargets="ModInfo" Condition="!Exists('Properties\localSettings.props')">

        <MakeDir Directories="Properties"/>
        <WriteLinesToFile File="Properties\localSettings.props" Overwrite="true" Lines="$(LocalSettingsPropsDefault)"/>
        <Error Text="Local settings file was missing, generated a new one. Run build again."/>
    </Target>
    <Target Name="EnsureModInfoProps" BeforeTargets="ModInfo" Condition="!Exists('Properties\modinfo.props')">
        <MakeDir Directories="Properties"/>
        <PropertyGroup>
        </PropertyGroup>
        <WriteLinesToFile File="Properties\modinfo.props" Overwrite="true" Lines="$(ModInfoPropsDefault)"/>
        <Error Text="ModInfo settings file was missing, generated a new one. Run build again."/>
    </Target>

    <Target Name="ResolveDependencies" Condition="'@(Dependency)' != ''" BeforeTargets="ResolveReferences">
        <PropertyGroup>
            <AbsoluteIntermediateOutput>$(ProjectDir)$(IntermediateOutputPath)</AbsoluteIntermediateOutput>
            <ModRefFolder>$(AbsoluteIntermediateOutput)\modDeps\</ModRefFolder>
        </PropertyGroup>
        <Dependencies Dependency="@(Dependency)" OutputDir="$(ModRefFolder)">
            <Output TaskParameter="ModsDownloaded" ItemName="VSMod"/>
        </Dependencies>
        <ItemGroup>
            <VSMods Include="%(VSMod.Folder)\lib\**\*.dll"/>
            <VSMods Include="%(VSMod.Folder)\**\*.dll" Condition=" '@(VSMods)' == '' "/>
        </ItemGroup>
        <ItemGroup>
            <Reference Include="@(VSMods)" Private="false"/>
        </ItemGroup>
    </Target>

    <Target Name="ModInfo" BeforeTargets="CopyFilesToOutput">
        <Message Text="Generating modinfo.json" Importance="high"/>
        <MakeModInfo Authors="$(Authors)" Description="$(Description)"
                     Version="$(Version)" ModId="$(PackageId)"
                     Name="$(Title)" Website="$(PackageProjectUrl)"
                     Contributors="$(Contributors)" Dependencies="@(Dependency)"
                     ModType="$(ModType)" Side="$(Side)"
                     RequiredOnClient="$(RequiredOnClient)"
                     RequiredOnServer="$(RequiredOnServer)"
                     FilePath="$(OutputPath)/modinfo.json"/>
    </Target>


    <Target Name="CopyFilesToOutput" AfterTargets="ModInfo" BeforeTargets="Format">
        <RemoveDir Directories="$(OutputPath)assets"/>
        <MakeDir Directories="$(OutputPath)assets"/>
        <Copy SourceFiles="$(ModIconFile)" DestinationFolder="$(OutputPath)" Condition="Exists('$(ModIconFile)')"/>
    </Target>

    <!-- Formats asssets files -->
    <Target Name="Format" AfterTargets="ModInfo" BeforeTargets="BeforeBuild">
        <JsonFormat Indent="$(JsonIndent)" Files="@(AssetsToFormat)" OutputPath="$(OutputPath)assets"/>
    </Target>

    <!-- Archives output directory into zip and puts it into Releases folder -->
    <Target Name="ZipFiles" AfterTargets="Build" Condition=" '$(Configuration)' == 'Release' ">
        <Message Text="Pachaging into '$(ReleaseFile)'" Importance="high"/>
        <Delete Files="$(OutputPath)\$(PackageId).dll" Condition="'$(ModType)' != 'code'"/>
        <Delete Files="$(OutputPath)\$(PackageId).pdb" Condition="'$(ModType)' != 'code'"/>
        <Delete Files="$(OutputPath)\$(PackageId).deps.json" Condition="'$(ModType)' != 'code'"/>
        <MakeDir Directories="$(ReleasesDir)"/>
        <Delete Files="$(ReleasePath)"/>
        <ZipDirectory SourceDirectory="$(OutputPath)" DestinationFile="$(ReleasePath)"/>
    </Target>
    <Target Name="ZipFilesDev" AfterTargets="Build" Condition=" '$(Configuration)' == 'Debug' and '$(PackageDevBuild)' == 'true'">
        <Message Text="Pachaging into '$(ReleaseFile)'" Importance="high"/>
        <Delete Files="$(OutputPath)\$(PackageId).dll" Condition="'$(ModType)' != 'code'"/>
        <Delete Files="$(OutputPath)\$(PackageId).pdb" Condition="'$(ModType)' != 'code'"/>
        <Delete Files="$(OutputPath)\$(PackageId).deps.json" Condition="'$(ModType)' != 'code'"/>
        <MakeDir Directories="$(ReleasesDir)"/>
        <Delete Files="$(ReleasePathDev)"/>
        <ZipDirectory SourceDirectory="$(OutputPath)" DestinationFile="$(ReleasePathDev)"/>
    </Target>
</Project>
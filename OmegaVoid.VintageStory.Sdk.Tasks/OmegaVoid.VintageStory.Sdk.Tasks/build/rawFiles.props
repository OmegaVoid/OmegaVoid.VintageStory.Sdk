<Project>
    <PropertyGroup>
        <LocalSettingsPropsDefault>
&lt;Project&gt;
    &lt;PropertyGroup&gt;
        &lt;WorldName&gt;test_$(ProjectId)&lt;/WorldName&gt;
        &lt;DataFolder&gt;&lt;/DataFolder&gt;
        &lt;GameDirectory&gt;&lt;/GameDirectory&gt;
        &lt;PackageDevBuild&gt;false&lt;/PackageDevBuild&gt;
        &lt;EnterWorldOnStartup&gt;false&lt;/EnterWorldOnStartup&gt;
        &lt;ApiKey&gt;&lt;/ApiKey&gt;
    &lt;/PropertyGroup&gt;
&lt;/Project&gt;
        </LocalSettingsPropsDefault>
        <ModInfoPropsDefault>
&lt;Project&gt;
    &lt;PropertyGroup&gt;
        &lt;Contributors&gt;fsdg&lt;/Contributors&gt;
        &lt;ModType&gt;code&lt;/ModType&gt;
        &lt;Side&gt;universal&lt;/Side&gt;
        &lt;RequiredOnClient&gt;true&lt;/RequiredOnClient&gt;
        &lt;RequiredOnServer&gt;true&lt;/RequiredOnServer&gt;
    &lt;/PropertyGroup&gt;
    &lt;ItemGroup&gt;
        &lt;!-- Fetch controls whether to automatically download the mod from moddb as a dependency --&gt;
        &lt;Dependency Include=&quot;game&quot; Version=&quot;*&quot; Fetch=&quot;false&quot;/&gt;
    &lt;/ItemGroup&gt;
&lt;/Project&gt; 
        </ModInfoPropsDefault>
    </PropertyGroup>
</Project>
<!-- build/OmegaVoid.VintageStory.Sdk.Tasks.props -->
<Project TreatAsLocalProperty="TaskFolder;TaskAssembly">
    <Import Project="$(MSBuildProjectDirectory)\Properties\localSettings.props" Condition="Exists('$(MSBuildProjectDirectory)\Properties\localSettings.props')"/>
    <Import Project="$(MSBuildProjectDirectory)\Properties\modinfo.props" Condition="Exists('$(MSBuildProjectDirectory)\Properties\modinfo.props')"/>
    <Import Project="$(MSBuildThisFileDirectory)\rawFiles.props"/>
    <Import Project="$(MSBuildThisFileDirectory)\vsReferences.props"/>
    <Import Project="$(MSBuildThisFileDirectory)\jsonAssetPaths.props"/>
    <Import Project="$(MSBuildThisFileDirectory)\directories.props"/>
<!--    <Import Project="$(MSBuildThisFileDirectory)\build.targets"/>-->
    
    <PropertyGroup>
        <IsPackable>true</IsPackable>
    </PropertyGroup>
    
    <ItemGroup>
        <Folder Include="resources\assets\$(PackageId)\"/>
    </ItemGroup>
    <ItemGroup>
        <None Remove="resources\assets"/>
    </ItemGroup>
    <ItemGroup>
        <Folder Include="resources\assets\" />
    </ItemGroup>
    
    <PropertyGroup>
        <TaskAssembly>$(MSBuildThisFileDirectory)..\tasks\net10.0\OmegaVoid.VintageStory.Sdk.Tasks.dll</TaskAssembly>
        <ModID>$(PackageId)</ModID>
    </PropertyGroup>
    
    <UsingTask TaskName="Dependencies" AssemblyFile="$(TaskAssembly)" Architecture="*" Runtime="CurrentRuntime"/>
    <UsingTask TaskName="MakeModInfo" AssemblyFile="$(TaskAssembly)" Architecture="*" Runtime="CurrentRuntime"/>
    <UsingTask TaskName="JsonFormat" AssemblyFile="$(TaskAssembly)" Architecture="*" Runtime="CurrentRuntime"/>


    
    <Target Name="Vars" BeforeTargets="ModInfo">
        <PropertyGroup>
            <ReleasesDir>$(ProjectDir)\Releases</ReleasesDir>
            <ReleaseFile>$(PackageId)_$(Version)</ReleaseFile>
            <ReleasePath>$(ReleasesDir)\$(ReleaseFile).zip</ReleasePath>
            <ReleasePathDev>$(ReleasesDir)\$(ReleaseFile)_dev.zip</ReleasePathDev>
        </PropertyGroup>
    </Target>
    <!-- Creating local settings file -->
    <Target Name="EnsureSettingsProps" DependsOnTargets="Vars" BeforeTargets="ModInfo" Condition="!Exists('Properties\localSettings.props')">

        <MakeDir Directories="Properties"/>
        <WriteLinesToFile File="Properties\localSettings.props" Overwrite="true" Lines="$(LocalSettingsPropsDefault)"/>
        <Error Text="Local settings file was missing, generated a new one. Run build again."/>
    </Target>
    <Target Name="EnsureModInfoProps" BeforeTargets="ModInfo" Condition="!Exists('Properties\modinfo.props')">
        <MakeDir Directories="Properties"/>
        <PropertyGroup>
        </PropertyGroup>
        <WriteLinesToFile File="Properties\modinfo.props" Overwrite="true" Lines="$(ModInfoPropsDefault)"/>
        <Error Text="ModInfo settings file was missing, generated a new one. Run build again."/>
    </Target>

    <Target Name="ResolveDependencies" Condition="'@(Dependency)' != ''" BeforeTargets="ResolveReferences">
        <PropertyGroup>
            <AbsoluteIntermediateOutput>$(ProjectDir)\$(IntermediateOutputPath)</AbsoluteIntermediateOutput>
            <ModRefFolder>$(AbsoluteIntermediateOutput)\modDeps\</ModRefFolder>
        </PropertyGroup>
        <Dependencies Dependency="@(Dependency)" OutputDir="$(ModRefFolder)">
            <Output TaskParameter="ModsDownloaded" ItemName="VSMod"/>
        </Dependencies>
        <ItemGroup>
            <VSMods Include="%(VSMod.Folder)\lib\**\*.dll"/>
            <VSMods Include="%(VSMod.Folder)\**\*.dll" Condition=" '@(VSMods)' == '' "/>
        </ItemGroup>
        <Message Importance="high" IsCritical="true" Text="@(VSMod)"/>
        <Message Importance="high" IsCritical="true" Text="%(VSMod.Folder)"/>
        <ItemGroup>
            <Reference Include="@(VSMods)" Private="false"/>
        </ItemGroup>
    </Target>

    <Target Name="ModInfo" BeforeTargets="CopyFilesToOutput">
        <Message Text="Generating modinfo.json" Importance="high"/>
        <MakeModInfo Authors="$(Authors)" 
                     Description="$(Description)"
                     Version="$(Version)" 
                     ModId="$(PackageId)"
                     Name="$(Title)" 
                     Website="$(PackageProjectUrl)"
                     Contributors="$(Contributors)" 
                     Dependencies="@(Dependency)"
                     ModType="$(ModType)" 
                     Side="$(Side)"
                     RequiredOnClient="$(RequiredOnClient)"
                     RequiredOnServer="$(RequiredOnServer)"
                     FilePath="$(OutputPath)/modinfo.json" 
                     IconPath="$(IconPath)" 
                     TextureSize="$(TextureSize)" 
                     NetworkVersion="$(NetworkVersion)"/>
    </Target>


    <Target Name="CopyFilesToOutput" AfterTargets="ModInfo" BeforeTargets="Format">
        <RemoveDir Directories="$(OutputPath)assets"/>
        <MakeDir Directories="$(OutputPath)assets"/>
        <Copy SourceFiles="$(ModIconFile)" DestinationFolder="$(OutputPath)" Condition="Exists('$(ModIconFile)')"/>
    </Target>

    <!-- Formats asssets files -->
    <Target Name="Format" AfterTargets="ModInfo" BeforeTargets="BeforeBuild">
        <JsonFormat Indent="$(JsonIndent)" Files="@(AssetsToFormat)" OutputPath="$(OutputPath)assets"/>
    </Target>

    <!-- Archives output directory into zip and puts it into Releases folder -->
    <Target Name="ZipFiles" DependsOnTargets="Vars" AfterTargets="Build" Condition=" '$(Configuration)' == 'Release' ">
        <Message Text="Packaging into '$(ReleasePath)'" Importance="high"/>
        <Delete Files="$(OutputPath)\$(PackageId).dll" Condition="'$(ModType)' != 'code'"/>
        <Delete Files="$(OutputPath)\$(PackageId).pdb" Condition="'$(ModType)' != 'code'"/>
        <Delete Files="$(OutputPath)\$(PackageId).deps.json" Condition="'$(ModType)' != 'code'"/>
        <MakeDir Directories="$(ReleasesDir)"/>
        <Delete Files="$(ReleasePath)"/>
        <ZipDirectory SourceDirectory="$(OutputPath)" DestinationFile="$(ReleasePath)"/>
    </Target>
    <Target Name="ZipFilesDev" AfterTargets="Build" Condition=" '$(Configuration)' == 'Debug' and '$(PackageDevBuild)' == 'true'">
        <Message Text="Pachaging into '$(ReleaseFile)'" Importance="high"/>
        <Delete Files="$(OutputPath)\$(PackageId).dll" Condition="'$(ModType)' != 'code'"/>
        <Delete Files="$(OutputPath)\$(PackageId).pdb" Condition="'$(ModType)' != 'code'"/>
        <Delete Files="$(OutputPath)\$(PackageId).deps.json" Condition="'$(ModType)' != 'code'"/>
        <MakeDir Directories="$(ReleasesDir)"/>
        <Delete Files="$(ReleasePathDev)"/>
        <ZipDirectory SourceDirectory="$(OutputPath)" DestinationFile="$(ReleasePathDev)"/>
    </Target>
    <ItemGroup>
        <Reference Include="$(ProjectDir)\$(IntermediateOutputPath)\modDeps\**\*.dll" Private="false"/>
    </ItemGroup>
</Project>

<!-- build/OmegaVoid.VintageStory.Sdk.Tasks.props -->
<Project TreatAsLocalProperty="TaskFolder;TaskAssembly" InitialTargets="Vars" >
    <Import Project="$(MSBuildProjectDirectory)\Properties\localSettings.props"
            Condition="Exists('$(MSBuildProjectDirectory)\Properties\localSettings.props')"/>
    <Import Project="$(MSBuildProjectDirectory)\Properties\modinfo.props"
            Condition="Exists('$(MSBuildProjectDirectory)\Properties\modinfo.props')"/>
    <Import Project="$(MSBuildThisFileDirectory)\rawFiles.props"/>
    <Import Project="$(MSBuildThisFileDirectory)\vsReferences.props"/>

    <PropertyGroup>
        <ProjectDir>$(MSBuildProjectDirectory)</ProjectDir>
        <OutputDir>bin\$(Configuration)\Mods</OutputDir>
        <OutputPath>$(OutputDir)\placeholderpackageid</OutputPath>
        <AssetsDir>$(ProjectDir)\resources\assets</AssetsDir>
        <ModIconFile>$(ProjectDir)\resources\modicon.png</ModIconFile>
        <ReleasesDir>$(ProjectDir)\Releases</ReleasesDir>
        <ExternalLibDir>$(ProjectDir)\external</ExternalLibDir>
        <GameDirectory Condition="'$(GameDirectory)' == ''">$(VINTAGE_STORY)</GameDirectory>
        <AbsoluteIntermediateOutput>$(ProjectDir)\obj\$(Configuration)</AbsoluteIntermediateOutput>
        <ModDir>$(ProjectDir)\$(OutputDir)</ModDir>
        <AdditionalModsFolder>$(DataFolder)\Mods</AdditionalModsFolder>
        <EnterWorldCommand Condition="'$(EnterWorldOnStartup)' == 'true'">"-o" "$(WorldName)"</EnterWorldCommand>
        <PackageOutputPath>bin\$(Configuration)</PackageOutputPath>
        <ModRefFolder>$(AbsoluteIntermediateOutput)\modDeps</ModRefFolder>
        <ModDepsFolder>$(AbsoluteIntermediateOutput)\Mods</ModDepsFolder>
    </PropertyGroup>

    <PropertyGroup>
        <IsPackable>true</IsPackable>
    </PropertyGroup>

    <ItemGroup>
<!--        <Folder Include="resources\assets\$(PackageId)\"/>-->
<!--        <None Remove="resources\assets"/>-->
<!--        <Folder Include="resources\assets\" />-->
        <Folder Include="Releases\"/>
    </ItemGroup>

    <PropertyGroup>
        <TaskAssembly>$(MSBuildThisFileDirectory)..\tasks\net10.0\OmegaVoid.VintageStory.Sdk.Tasks.dll</TaskAssembly>
        <ModID>$(PackageId)</ModID>
    </PropertyGroup>

    <UsingTask TaskName="Dependencies" AssemblyFile="$(TaskAssembly)" Architecture="x64" Runtime="NET"/>
    <UsingTask TaskName="MakeModInfo" AssemblyFile="$(TaskAssembly)" Architecture="x64" Runtime="NET"/>
    <UsingTask TaskName="JsonFormat" AssemblyFile="$(TaskAssembly)" Architecture="x64" Runtime="NET"/>


    <Target Name="Vars" BeforeTargets="ModInfo">
        <MakeDir Directories="resources\assets\$(PackageId)"/>
        <PropertyGroup>
            <ProjectDir>$(MSBuildProjectDirectory)</ProjectDir>
            <OutputDir>bin\$(Configuration)\Mods</OutputDir>
            <OutputPath>$(OutputDir)\$(PackageId)</OutputPath>
            <AssetsDir>$(ProjectDir)\resources\assets</AssetsDir>
            <ModIconFile>$(ProjectDir)\resources\modicon.png</ModIconFile>
            <ReleasesDir>$(ProjectDir)\Releases</ReleasesDir>
            <ReleaseFile>$(PackageId)_$(Version)</ReleaseFile>
            <ReleasePath>$(ReleasesDir)\$(ReleaseFile).zip</ReleasePath>
            <ReleasePathDev>$(ReleasesDir)\$(ReleaseFile)_dev.zip</ReleasePathDev>
            <ExternalLibDir>$(ProjectDir)\external</ExternalLibDir>
            <GameDirectory Condition="'$(GameDirectory)' == ''">$(VINTAGE_STORY)</GameDirectory>
            <AbsoluteIntermediateOutput>$(ProjectDir)$(IntermediateOutputPath)</AbsoluteIntermediateOutput>
            <ModDir>$(ProjectDir)\$(OutputDir)</ModDir>
            <AdditionalModsFolder>$(DataFolder)\Mods</AdditionalModsFolder>
            <EnterWorldCommand Condition="'$(EnterWorldOnStartup)' == 'true'">"-o" "$(WorldName)"</EnterWorldCommand>
            <PackageOutputPath>bin\$(Configuration)</PackageOutputPath>
        </PropertyGroup>

        <Message Importance="high" Text="ProjectDir = $(ProjectDir)"/>
        <Message Importance="high" Text="OutputDir = $(OutputDir)"/>
        <Message Importance="high" Text="OutputDir2 = $(OutputDir2)"/>
        <Message Importance="high" Text="OutputPath = $(OutputPath)"/>
        <Message Importance="high" Text="OutputPath2 = $(OutputPath2)"/>
        <Message Importance="high" Text="AssetsDir = $(AssetsDir)"/>
        <Message Importance="high" Text="ModIconFile = $(ModIconFile)"/>
        <Message Importance="high" Text="ReleasesDir = $(ReleasesDir)"/>
        <Message Importance="high" Text="ReleaseFile = $(ReleaseFile)"/>
        <Message Importance="high" Text="ReleasePath = $(ReleasePath)"/>
        <Message Importance="high" Text="ReleasePathDev = $(ReleasePathDev)"/>
        <Message Importance="high" Text="ExternalLibDir = $(ExternalLibDir)"/>
        <Message Importance="high" Text="GameDirectory = $(GameDirectory)"/>
        <Message Importance="high" Text="AbsoluteIntermediateOutput = $(AbsoluteIntermediateOutput)"/>
        <Message Importance="high" Text="ModDir = $(ModDir)"/>
        <Message Importance="high" Text="AdditionalModsFolder = $(AdditionalModsFolder)"/>
        <Message Importance="high" Text="EnterWorldCommand = $(EnterWorldCommand)"/>
        <Message Importance="high" Text="PackageOutputPath = $(PackageOutputPath)"/>

        <ItemGroup>
            <AssetsToFormat BaseDir="$(AssetsDir)" Include="$(AssetsDir)\$(PackageId)"/>
            <!--            <AssetsToFormat BaseDir="$(AssetsDir)" Include="$(AssetsDir)\$(PackageId)\config" />-->
            <!--            <AssetsToFormat BaseDir="$(AssetsDir)" Include="$(AssetsDir)\$(PackageId)\dialog" />-->
            <!--            <AssetsToFormat BaseDir="$(AssetsDir)" Include="$(AssetsDir)\$(PackageId)\entities" />-->
            <!--            <AssetsToFormat BaseDir="$(AssetsDir)" Include="$(AssetsDir)\$(PackageId)\itemtypes" />-->
            <!--            <AssetsToFormat BaseDir="$(AssetsDir)" Include="$(AssetsDir)\$(PackageId)\lang" />-->
            <!--            <AssetsToFormat BaseDir="$(AssetsDir)" Include="$(AssetsDir)\$(PackageId)\music" />-->
            <!--            <AssetsToFormat BaseDir="$(AssetsDir)" Include="$(AssetsDir)\$(PackageId)\patches" />-->
            <!--            <AssetsToFormat BaseDir="$(AssetsDir)" Include="$(AssetsDir)\$(PackageId)\worldproperties" />-->
            <!--            <AssetsToFormat BaseDir="$(AssetsDir)" Include="$(AssetsDir)\$(PackageId)\sounds" />-->
            <!--            <AssetsToFormat BaseDir="$(AssetsDir)" Include="$(AssetsDir)\$(PackageId)\shapes" />-->
            <!--            <AssetsToFormat BaseDir="$(AssetsDir)" Include="$(AssetsDir)\$(PackageId)\recipes" />-->
            <!--            <AssetsToFormat BaseDir="$(AssetsDir)" Include="$(AssetsDir)\$(PackageId)\worldgen" />-->
        </ItemGroup>
        <Message Importance="low" Text="AssetsToFormat = @(AssetsToFormat)"/>

    </Target>
    <!-- Creating local settings file -->
    <Target Name="EnsureSettingsProps" DependsOnTargets="Vars" BeforeTargets="ModInfo"
            Condition="!Exists('Properties\localSettings.props')">

        <MakeDir Directories="Properties"/>
        <WriteLinesToFile File="Properties\localSettings.props" Overwrite="true" Lines="$(LocalSettingsPropsDefault)"/>
        <Error Text="Local settings file was missing, generated a new one. Run build again."/>
    </Target>
    <Target Name="EnsureModInfoProps" DependsOnTargets="Vars" BeforeTargets="ModInfo"
            Condition="!Exists('Properties\modinfo.props')">
        <MakeDir Directories="Properties"/>
        <PropertyGroup>
        </PropertyGroup>
        <WriteLinesToFile File="Properties\modinfo.props" Overwrite="true" Lines="$(ModInfoPropsDefault)"/>
        <Error Text="ModInfo settings file was missing, generated a new one. Run build again."/>
    </Target>

    <Target Name="ResolveDependencies" DependsOnTargets="Vars" Condition="'@(Dependency)' != ''"
            BeforeTargets="ResolveReferences">
        <PropertyGroup>
            <AbsoluteIntermediateOutput>$(ProjectDir)\$(IntermediateOutputPath)</AbsoluteIntermediateOutput>
            <ModRefFolder>$(AbsoluteIntermediateOutput)\modDeps\</ModRefFolder>
            <ModDepsFolder>$(AbsoluteIntermediateOutput)\Mods\</ModDepsFolder>
        </PropertyGroup>
        <Dependencies Dependency="@(Dependency)" OutputDir="$(ModRefFolder)" DependencyDir="$(ModDepsFolder)"/>
    </Target>

    <Target Name="MakeOutput" DependsOnTargets="Vars" BeforeTargets="ModInfo" Condition="!Exists('$(OutputPath)')">
        <MakeDir Directories="$(OutputPath)"/>
    </Target>

    <Target Name="ModInfo" DependsOnTargets="Vars" BeforeTargets="CopyFilesToOutput">
        <Message Text="Generating modinfo.json" Importance="high"/>
        <MakeModInfo Authors="$(Authors)"
                     Description="$(Description)"
                     Version="$(Version)"
                     ModId="$(PackageId)"
                     Name="$(Title)"
                     Website="$(PackageProjectUrl)"
                     Contributors="$(Contributors)"
                     Dependencies="@(Dependency)"
                     ModType="$(ModType)"
                     Side="$(Side)"
                     RequiredOnClient="$(RequiredOnClient)"
                     RequiredOnServer="$(RequiredOnServer)"
                     FilePath="$(OutputPath)/modinfo.json"
                     IconPath="$(IconPath)"
                     TextureSize="$(TextureSize)"
                     NetworkVersion="$(NetworkVersion)"/>
    </Target>


    <Target Name="CopyFilesToOutput" DependsOnTargets="Vars" AfterTargets="ModInfo" BeforeTargets="Format">
        <RemoveDir Directories="$(OutputPath)\assets"/>
        <MakeDir Directories="$(OutputPath)\assets"/>
        <ItemGroup>
            <AssetsCopy Include="$(AssetsDir)\**\*.*"/>
            <AssetsCopy Remove="$(AssetsDir)\**\*.json"/>
            <AssetsCopy Remove="$(AssetsDir)\**\*.json5"/>
        </ItemGroup>
        <Copy SourceFiles="@(AssetsCopy)" DestinationFiles="@(AssetsCopy->'%(Identity)'->Replace('$(AssetsDir)', '$(OutputPath)\assets'))" SkipUnchangedFiles="true"/>
        <Copy SourceFiles="$(ModIconFile)" DestinationFolder="$(OutputPath)" Condition="Exists('$(ModIconFile)')"/>
    </Target>

    <!-- Formats asssets files -->
    <Target Name="Format" DependsOnTargets="Vars" AfterTargets="CopyFilesToOutput" BeforeTargets="BeforeBuild">
        <JsonFormat Indent="$(JsonIndent)" Files="@(AssetsToFormat)" OutputPath="$(OutputPath)\assets"/>
    </Target>

    <!-- Archives output directory into zip and puts it into Releases folder -->
    <Target Name="ZipFiles" DependsOnTargets="Vars" AfterTargets="Build" Condition=" '$(Configuration)' == 'Release' ">
        <ItemGroup>
            <Placeholders Include="$(OutputDir)\placeholderpackageid\**\*.*"/>
        </ItemGroup>
        <Move SourceFiles="@(Placeholders)" DestinationFolder="$(OutputDir)\$(PackageId)"/>
        <Delete Files="$(OutputDir)\placeholderpackageid"/>
        <Message Text="Packaging into '$(ReleasePath)'" Importance="high"/>
        <Delete Files="$(OutputPath)\$(PackageId).dll" Condition="'$(ModType)' != 'code'"/>
        <Delete Files="$(OutputPath)\$(PackageId).pdb" Condition="'$(ModType)' != 'code'"/>
        <Delete Files="$(OutputPath)\$(PackageId).deps.json" Condition="'$(ModType)' != 'code'"/>
        <MakeDir Directories="$(ReleasesDir)"/>
        <Delete Files="$(ReleasePath)"/>
        <ZipDirectory SourceDirectory="$(OutputPath)" DestinationFile="$(ReleasePath)"/>
    </Target>
    <Target Name="ZipFilesDev" DependsOnTargets="Vars" AfterTargets="Build"
            Condition=" '$(Configuration)' == 'Debug' and '$(PackageDevBuild)' == 'true'">
        <ItemGroup>
            <Placeholders Include="$(OutputDir)\placeholderpackageid\**\*.*"/>
        </ItemGroup>
        <Move SourceFiles="@(Placeholders)" DestinationFolder="$(OutputPath)"/>
        <Delete Files="$(OutputDir)\placeholderpackageid"/>
        <Message Text="Pachaging into '$(ReleaseFile)'" Importance="high"/>
        <Delete Files="$(OutputPath)\$(PackageId).dll" Condition="'$(ModType)' != 'code'"/>
        <Delete Files="$(OutputPath)\$(PackageId).pdb" Condition="'$(ModType)' != 'code'"/>
        <Delete Files="$(OutputPath)\$(PackageId).deps.json" Condition="'$(ModType)' != 'code'"/>
        <MakeDir Directories="$(ReleasesDir)"/>
        <Delete Files="$(ReleasePathDev)"/>
        <ZipDirectory SourceDirectory="$(OutputPath)" DestinationFile="$(ReleasePathDev)"/>
    </Target>
    <ItemGroup>
        <Reference Include="$(ProjectDir)\$(IntermediateOutputPath)\modDeps\**\*.dll" Private="false"/>
    </ItemGroup>
</Project>
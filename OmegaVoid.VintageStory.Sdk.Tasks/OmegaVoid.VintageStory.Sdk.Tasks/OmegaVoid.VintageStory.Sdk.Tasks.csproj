<Project Sdk="Microsoft.NET.Sdk">
    
<!--    <Import Project="build\OmegaVoid.VintageStory.Sdk.Tasks.props" />-->

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <IsPackable>false</IsPackable>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>

        <RootNamespace>OmegaVoid.VintageStory.Sdk.Tasks</RootNamespace>
        <PackageId>OmegaVoid.VintageStory.Sdk.Tasks</PackageId>
        <BuildOutputTargetFolder>tasks</BuildOutputTargetFolder>
        <NoPackageAnalysis>true</NoPackageAnalysis>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Build.Tasks.Core" Version="18.4.0" />

        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.14.0"/>
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.14.0"/>
        <PackageReference Include="Newtonsoft.Json" Version="13.0.5-beta1" />

        <PackageReference Update="@(PackageReference)" PrivateAssets="All" />
    </ItemGroup>


</Project>

<Project Sdk="Microsoft.NET.Sdk">
    
    <Import Project="Properties\localSettings.props" />

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <IsPackable>true</IsPackable>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>

        <RootNamespace>OmegaVoid.VintageStory.Sdk.Tasks</RootNamespace>
        <PackageId>OmegaVoid.VintageStory.Sdk.Tasks</PackageId>
        <BuildOutputTargetFolder>tasks</BuildOutputTargetFolder>
        <NoPackageAnalysis>true</NoPackageAnalysis>
        <Title>Vintage Story Build</Title>
        <Authors>OmegaRogue</Authors>
        <Copyright>Copyright (c) OmegaRogue 2026.</Copyright>
        <PackageLicenseExpression>LGPL-3.0-or-later</PackageLicenseExpression>
        <PackageProjectUrl>github.com/OmegaVoid/OmegaVoid.VintageStory.Sdk</PackageProjectUrl>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <Version>0.1.0</Version>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Build.Tasks.Core" Version="18.4.0" />
        <PackageReference Include="Newtonsoft.Json" Version="13.0.5-beta1" />

        <PackageReference Update="@(PackageReference)" PrivateAssets="All" />
    </ItemGroup>

    <ItemGroup>
        <!-- pack the props files -->
        <Content Include="build\OmegaVoid.VintageStory.Sdk.Tasks.props" PackagePath="build\" />
        <Content Include="build\build.targets" PackagePath="build\" />
        <Content Include="build\directories.props" PackagePath="build\" />
        <Content Include="build\jsonAssetPaths.props" PackagePath="build\" />
        <Content Include="build\rawFiles.props" PackagePath="build\" />
        <Content Include="build\vsReferences.props" PackagePath="build\" />
    </ItemGroup>


</Project>

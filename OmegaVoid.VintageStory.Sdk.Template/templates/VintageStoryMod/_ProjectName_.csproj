<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
        <Nullable>enable</Nullable>
        <PackageId>_modid_</PackageId>
        <Version>_ModVersion_</Version>
        <Title>_ProjectName_</Title>
        <Authors>_ModAuthors_</Authors>
        <Description>_ModDescription_</Description>
        <PackageProjectUrl>_ModWebsite_</PackageProjectUrl>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <IsPackable>true</IsPackable>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="OmegaVoid.VintageStory.Sdk.Tasks" Version="0.3.*"/>
    </ItemGroup>
</Project>